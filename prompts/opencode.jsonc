{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "reboot",
  "agent": {
    "reboot": {
      "mode": "primary",
      "model": "anthropic/claude-sonnet-4-5-20250929",
      "prompt": "{file:./codex_reboot.txt}",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true
      }
    }
  },
  "mcp": {
    "reboot-mcp": {
      "type": "remote",
      "url": "http://localhost:8000/mcp",
      "enabled": true
    }
  }
}
